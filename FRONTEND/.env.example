# Frontend API Configuration
# Use this file as a template for your .env file

# ========================
# DEVELOPMENT ENVIRONMENT
# ========================
# For local development, use localhost
# VITE_API_URL=http://localhost:5000/api

# ========================
# PRODUCTION ENVIRONMENT
# ========================
# After deploying backend to Render, use the production URL
# Replace the URL below with your actual Render backend URL
VITE_API_URL=https://job-portal-backend.onrender.com/api

# Note: 
# - The VITE_ prefix is required for Vite to expose variables to client-side code
# - Use http://localhost:5000/api for local development
# - Use https://job-portal-backend.onrender.com/api for production
# - Update this URL after you deploy your backend to Render
# - Do NOT commit secrets or API keys to version control
