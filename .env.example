# Backend Configuration
# Use this file as a template for your .env file
# NEVER commit your actual .env file - this is just an example!

# ========================
# MONGODB CONFIGURATION
# ========================
# MongoDB connection string from Atlas
# Format: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/database
# Get this from MongoDB Atlas after creating your cluster
MONGO_URI=mongodb://localhost:27017/jobportal

# ========================
# SERVER CONFIGURATION
# ========================
# Port for your Express server
PORT=5000

# ========================
# ENVIRONMENT MODE
# ========================
# Set to 'development' for local, 'production' after deploying
NODE_ENV=development

# ========================
# DEPLOYMENT INSTRUCTIONS
# ========================
# For local development:
#   - Use mongodb://localhost:27017/jobportal
#   - Use PORT=5000
#   - Use NODE_ENV=development

# For production on Render:
#   - Use your MongoDB Atlas connection string (from MongoDB Atlas console)
#   - Use PORT=5000 (Render assigns port automatically)
#   - Use NODE_ENV=production
#   - Add these variables in Render environment settings

# ========================
# MongoDB Atlas Setup (Free Tier)
# ========================
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create a cluster (M0 free tier)
# 3. Create a database user with password
# 4. Whitelist IP: 0.0.0.0/0 (allows all IPs)
# 5. Get connection string: mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/database
# 6. Replace 'user' and 'pass' with your credentials
# 7. Update MONGO_URI below

# ========================
# EXAMPLE PRODUCTION MongoDB Atlas Connection String
# ========================
# MONGO_URI=mongodb+srv://jobportaluser:securePassword@cluster0.xxxxx.mongodb.net/jobportal?retryWrites=true&w=majority
